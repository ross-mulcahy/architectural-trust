{
	"landingPage": "/",
	"preferredVersions": {
		"php": "8.2",
		"wp": "latest"
	},
	"features": {
		"networking": true
	},
	"steps": [
		{
			"step": "installTheme",
			"themeData": {
				"resource": "url",
				"url": "https://github.com/ross-mulcahy/architectural-trust/archive/refs/heads/main.zip"
			},
			"options": {
				"activate": true
			}
		},
		{
			"step": "setSiteOptions",
			"options": {
				"blogname": "Architectural Trust",
				"blogdescription": "The Institutional Standard",
				"show_on_front": "posts",
				"permalink_structure": "/%postname%/"
			}
		}
	]
}
