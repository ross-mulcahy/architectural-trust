{
	"landingPage": "/",
	"preferredVersions": {
		"php": "8.2",
		"wp": "latest"
	},
	"features": {
		"networking": true
	},
	"steps": [
		{
			"step": "installTheme",
			"themeData": {
				"resource": "url",
				"url": "https://github.com/ross-mulcahy/architectural-trust/archive/refs/heads/main.zip"
			},
			"options": {
				"activate": true
			}
		},
		{
			"step": "setSiteOptions",
			"options": {
				"blogname": "Architectural Trust",
				"blogdescription": "The Institutional Standard",
				"show_on_front": "page",
				"permalink_structure": "/%postname%/"
			}
		},
		{
			"step": "runPHP",
			"code": "<?php\nrequire '/wordpress/wp-load.php';\n$seed_file = get_theme_file_path( 'demo/seed-demo-content.php' );\nif ( file_exists( $seed_file ) ) {\n\trequire_once $seed_file;\n\tarchitectural_trust_seed_demo_content();\n\techo 'Demo content created';\n}\n?>"
		}
	]
}
